.small-button {
    width: 25px;
}

.flex-grow {
    flex-grow: 1;
}

.no-flex-grow {
    flex-grow: 0;
}

.flex-shrink {
    flex-shrink: 1;
}

.no-flex-shrink {
    flex-shrink: 0;
}

.flex-horizontal {
    flex-direction: row;
}

.flex-vertical {
    flex-direction: column;
}

.faded-text {
    opacity: 0.3;
}
